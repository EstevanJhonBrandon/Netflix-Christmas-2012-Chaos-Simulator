# ══════════════════════════════════════════════════════════════════
#  Netflix Christmas 2012 — Chaos Simulator
#  Variables reales — docker compose las carga automáticamente
# ══════════════════════════════════════════════════════════════════

# ── Cassandra ────────────────────────────────────────────────────
CASSANDRA_CLUSTER_NAME=netflix_sim
CASSANDRA_DC_PRIMARY=dc-east-1
CASSANDRA_DC_REPLICA=dc-east-2
CASSANDRA_REPLICATION_FACTOR=3
CASSANDRA_CONSISTENCY_LEVEL=LOCAL_QUORUM

# ── Kafka ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_INTERNAL=kafka:29092
KAFKA_BOOTSTRAP_EXTERNAL=localhost:9092
KAFKA_REPLICATION_FACTOR=1
KAFKA_NUM_PARTITIONS=6

# ── Vault ────────────────────────────────────────────────────────
VAULT_TOKEN=netflix-sim-root-token
VAULT_ADDR=http://vault:8200

# ── API (FastAPI) ─────────────────────────────────────────────────
API_PORT=8000
ENVIRONMENT=simulation
STARTUP_TIMEOUT_SECONDS=180

# ── Chaos Engine ─────────────────────────────────────────────────
CHAOS_PORT=8001

# ── Streaming (Node.js) ──────────────────────────────────────────
STREAMING_PORT=3000
LATENCY_INJECTION_MS=0

# ── Grafana ──────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=netflix2012

# ── Airflow — PostgreSQL backend ──────────────────────────────────
# SQLite no es compatible con LocalExecutor (no soporta concurrencia).
# PostgreSQL es el backend recomendado para Airflow en producción y dev.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=netflix2012
AIRFLOW_FERNET_KEY=bmV0ZmxpeC1zaW0tZmVybmV0LWtleS1jaGFuZ2U=

# PostgreSQL para metadata de Airflow (credenciales internas)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# ── Frontend build args ───────────────────────────────────────────
# Vacíos = nginx proxy maneja /api, /chaos-api, /sse internamente.
# Para dev local fuera de Docker usar:
#   VITE_API_URL=http://localhost:8000
#   VITE_CHAOS_URL=http://localhost:8001
#   VITE_SSE_URL=http://localhost:3000
VITE_API_URL=
VITE_CHAOS_URL=
VITE_SSE_URL=
