# ══════════════════════════════════════════════════════════════════════════
# Netflix Christmas 2012 Chaos Simulator — Variables de entorno
# ══════════════════════════════════════════════════════════════════════════
#
# NOTAS IMPORTANTES:
#
# 1. Las variables UP, EXPECTED_UP, i y topic que aparecían en los warnings
#    de Docker Compose eran variables de bash usadas DENTRO del script de
#    cassandra-init y kafka-init. Están escapadas con $$ en el compose file
#    para que Docker Compose no intente interpolación. NO deben definirse aquí.
#
# 2. Las variables VITE_* se dejan vacías intencionalmente → Vite usa los
#    valores por defecto de src/api/client.js (localhost:8000/8001/3000).
#    Define estas variables solo si despliegas el frontend en un host distinto.
#
# ──────────────────────────────────────────────────────────────────────────

# ── Cassandra ─────────────────────────────────────────────────────────────
CASSANDRA_CLUSTER_NAME=netflix_sim
CASSANDRA_DC_PRIMARY=dc-east-1
CASSANDRA_DC_REPLICA=dc-east-2
CASSANDRA_REPLICATION_FACTOR=3
CASSANDRA_CONSISTENCY_LEVEL=LOCAL_QUORUM

# ── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_INTERNAL=kafka:29092
KAFKA_BOOTSTRAP_EXTERNAL=localhost:9092
# Estos valores los usa el broker Kafka para configurarse.
# El script kafka-init usa literales (6 y 1) para no depender
# de la interpolación de Compose dentro del comando bash.
KAFKA_REPLICATION_FACTOR=1
KAFKA_NUM_PARTITIONS=6

# ── Vault ─────────────────────────────────────────────────────────────────
VAULT_TOKEN=netflix-sim-root-token
VAULT_ADDR=http://vault:8200

# ── API / servicios ───────────────────────────────────────────────────────
API_PORT=8000
CHAOS_PORT=8001
STREAMING_PORT=3000
ENVIRONMENT=simulation

# Latencia en ms que el streaming service inyecta en cada respuesta.
# 0 = sin latencia artificial. Se puede cambiar en caliente desde el
# Chaos Engine o vía POST http://localhost:3000/admin/latency
LATENCY_INJECTION_MS=0

# Tiempo máximo (segundos) que el API espera a conectar con Cassandra.
# Con 6 nodos y start_period=180s en los healthchecks, 300s es suficiente.
# Ajustar a 420 en máquinas lentas (< 8 GB RAM disponibles para Docker).
STARTUP_TIMEOUT_SECONDS=300

# ── Grafana ───────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=netflix2012

# ── Airflow ───────────────────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=netflix2012
# Clave Fernet para cifrar conexiones en Airflow. Generar una propia con:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=bmV0ZmxpeC1zaW0tZmVybmV0LWtleS1jaGFuZ2U=
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# ── Frontend (Vite) ───────────────────────────────────────────────────────
# Dejar vacío para usar localhost. Definir solo en despliegues remotos:
#   VITE_API_URL=http://mi-servidor:8000
VITE_API_URL=
VITE_CHAOS_URL=
VITE_SSE_URL=
